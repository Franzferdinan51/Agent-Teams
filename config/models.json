  "endpoints": {
    "openai": "https://api.openai.com/v1/chat/completions",
    "anthropic": "https://api.anthropic.com/v1/messages",
    "minimax": "https://api.minimax.io/v1/chat/completions",
    "kimi": "https://api.moonshot.cn/v1/chat/completions",
    "lmstudio": "http://localhost:1234/v1",
    "lmlink": "http://localhost:1234/v1"
  },

  "routing": {
    "_note": "How to route tasks to models",
    "default": "PRIMARY",
    "fallbackChain": ["PRIMARY", "FAST_LOCAL"],
    "byTask": {
      "vision": "VISION",
      "screenshot": "VISION",
      "code": "CODER",
      "debug": "CODER",
      "research": "PRIMARY",
      "reasoning": "REASONING",
      "quick": "FAST_LOCAL",
      "terminal": "LOCAL_WINDOWS"
    }
  },

  "budget": {
    "maxTokensPerTask": 50000,
    "maxTimeMs": 300000,
    "maxConcurrent": 5,
    "dailyTokenLimit": 1000000,
    "costLimitDaily": 100
  },

  "scoring": {
    "enabled": true,
    "trackSuccessRates": true,
    "feedbackEnabled": true,
    "autoRank": true
  },

  "memory": {
    "enabled": true,
    "persistSessions": true,
    "crossSessionRecall": true,
    "maxMemories": 10000
  },

  "tracing": {
    "enabled": true,
    "logDecisions": true,
    "visualize": true
  }
}