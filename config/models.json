    "LOCAL_WINDOWS": {
      "_note": "Windows machine via LM Link (for users with dedicated GPU PC)",
      "name": "CHANGE ME: Windows Local Model",
      "provider": "CHANGE ME: lmlink",
      "model": "CHANGE ME: qwen3.6-35b | llama-3-70b | mixtral",
      "apiKey": "CHANGE ME: set LM_LINK_KEY",
      "endpoint": "CHANGE ME: http://192.168.1.100:1234 (your Windows IP)",
      "enabled": false,
      "context": "CHANGE ME: 128000",
      "speed": "CHANGE ME: fast",
      "cost": "CHANGE ME: free",
