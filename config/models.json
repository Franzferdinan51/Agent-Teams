      "apiKey": "CHANGE ME: $YOUR_API_KEY or 'lm-studio' for local",
      "endpoint": "CHANGE ME: see endpoints below",
      "enabled": true,
      "context": "CHANGE ME: 128000",
      "speed": "CHANGE ME: fast | medium | slow",
      "cost": "CHANGE ME: free | low | medium | high",
      "bestFor": ["general", "agents", "research", "orchestration"]
    },

    "FAST_LOCAL": {
      "_note": "Fast free local model - great for quick tasks",
      "name": "CHANGE ME: Fast Local Model",
      "provider": "CHANGE ME: lmstudio | lmlink",
      "model": "CHANGE ME: qwen3.5-9b | llama-3-8b | mistral-7b",
      "apiKey": "CHANGE ME: 'lm-studio' or set LM_STUDIO_KEY",
      "endpoint": "CHANGE ME: http://localhost:1234/v1",
      "enabled": true,
      "context": "CHANGE ME: 32000",
      "speed": "CHANGE ME: very-fast",
      "cost": "CHANGE ME: free",
      "bestFor": ["quick-tasks", "local-inference", "privacy"]
    },

    "VISION": {
      "_note": "Screenshot and image analysis",
      "name": "CHANGE ME: Vision Model",
      "provider": "CHANGE ME: openai | anthropic | minimax | kimi",
      "model": "CHANGE ME: gpt-4o | claude-3-5-sonnet | MiniMax-M2.7 | moonshot-v1-8k",
      "apiKey": "CHANGE ME: $YOUR_API_KEY",
      "endpoint": "CHANGE ME: see endpoints below",
