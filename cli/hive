#!/bin/bash
# Hive CLI - Cross-Platform Entry Point
#
# Install:
#   Mac/Linux:  ln -s /path/to/hive /usr/local/bin/hive
#   Termux:     ln -s /path/to/hive ~/bin/hive
#
# Or just run directly:
#   node cli/index.js <command>

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
NODE_BIN="$SCRIPT_DIR/../node_modules/.bin/node"

# Find Node.js
if [ -x "$NODE_BIN" ]; then
    NODE="$NODE_BIN"
elif command -v node &> /dev/null; then
    NODE="node"
elif command -v nodejs &> /dev/null; then
    NODE="nodejs"
else
    echo "Error: Node.js not found"
    exit 1
fi

# Run Hive CLI
cd "$SCRIPT_DIR/.."
exec "$NODE" cli/index.js "$@"